rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        request.auth.token.email == 'narhsnazzisco@gmail.com'
      );
      allow write: if request.auth != null && request.auth.uid == userId;

      // A user's own orders subcollection (mirrors the main `orders` collection)
      match /orders/{orderId} {
        allow create: if request.auth != null
                       && request.auth.uid == userId
                       && request.resource.data.userId == request.auth.uid;
        allow read: if request.auth != null && (
          request.auth.uid == userId ||
          request.auth.token.email == 'narhsnazzisco@gmail.com'
        );
        allow update, delete: if false;
      }
    }

    // Orders collection
    match /orders/{orderId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        request.auth.token.email == 'narhsnazzisco@gmail.com'
      );
      allow update, delete: if request.auth != null &&
        request.auth.token.email == 'narhsnazzisco@gmail.com';
    }

    // Products catalog — public storefront: anyone can read, only admins write.
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null &&
        request.auth.token.email == 'narhsnazzisco@gmail.com';
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.auth.token.email == 'narhsnazzisco@gmail.com';
      allow update: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        resource.data.userId == 'all' ||
        request.auth.token.email == 'narhsnazzisco@gmail.com'
      ) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt']);
      allow delete: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        resource.data.userId == 'all' ||
        request.auth.token.email == 'narhsnazzisco@gmail.com'
      );
    }
  }
}
