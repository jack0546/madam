rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection
    match /users/{userId} {
      // A user can read their own profile; admins can read any profile.
      // NOTE: `read` already covers both `get` and `list`, so do not also
      // declare `allow list` here — doing so is a rules compile error and
      // prevents the entire ruleset from deploying.
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
      allow write: if request.auth != null && request.auth.uid == userId;

      // A user's own orders subcollection (mirrors the main `orders` collection)
      match /orders/{orderId} {
        allow create: if request.auth != null
                       && request.auth.uid == userId
                       && request.resource.data.userId == request.auth.uid;
        allow read: if request.auth != null && request.auth.uid == userId;
        allow update, delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Orders collection
    match /orders/{orderId} {
      // Authenticated users create orders tied to their own userId
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;

      // Users can read their own orders, admins can read all. `read` covers
      // both `get` and `list`, so the `where(userId == uid)` query is
      // authorized by the `resource.data.userId == request.auth.uid` branch.
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );

      // Only admins can update/delete orders
      allow update, delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Products catalog — public storefront: anyone can read, only admins write.
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
