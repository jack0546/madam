{
  "name": "order-system-functions",
  "version": "1.0.0",
  "description": "Cloud Functions for Order Management System",
  "main": "index.js",
  "scripts": {
    "lint": "eslint .",
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "config:ai": "firebase functions:config:set ai.api_key=\"$OPENAI_API_KEY\" ai.base_url=\"$AI_BASE_URL\" ai.model=\"$AI_MODEL\""
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "firebase-admin": "^12.6.0",
    "firebase-functions": "^6.3.0",
    "axios": "^1.7.9"
  },
  "devDependencies": {
    "eslint": "^9.17.0"
  },
  "private": true
}
