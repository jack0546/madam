# Paystack Configuration
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
SITE_URL=http://localhost:8000/order-system

# ─── AI Shopping Assistant (server-side only — NEVER expose to the browser) ───
# Set the provider API key for the LLM used by the AI assistant Cloud Functions.
# Any OpenAI-compatible provider works (Azure OpenAI, OpenRouter, Together, etc.)
OPENAI_API_KEY=sk-your-llm-provider-key
AI_BASE_URL=https://api.openai.com/v1
# Optional: override the default model
AI_MODEL=gpt-4o-mini
